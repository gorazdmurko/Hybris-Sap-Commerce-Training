## messageSource=classpath:/yacceleratorcore/messages/email-orderCancelled_$lang.properties
#macro( genHtmlBoldFont $text )
<font color="#414a4f" size="2" face="Arial, Helvetica, sans-serif"><b>$text</b></font>
#end
#macro(genHtmlLinkStartTag $url)
<a href="$url"><font color="#666666">
#end
#macro(genHtmlLinkEndTag)
</font></a>
#end
#macro(genHtmlLink $url $textColor $bodyContent)
<a href="$url"><font color="$textColor">$bodyContent</font></a>
#end

<html>
    <head></head>
    <body bgcolor="#ffffff">

        Hey, ${ctx.displayName}!

        <div>
            Your cart can become a gold cart if you do a purchase of 200 pounds. Once your cart becomes gold cart by adding cart total greater than 200 Pounds, you will get 80% discount on your gold cart.
            <br />
            Thanx and Regards,
            Hybris Tube Sales Team

            <hr />

            <h5>Title: ${ctx.title}</h5>
            <h5>Mail to: ${ctx.email}</h5>
            <h5>Mail from: ${ctx.fromEmail}</h5>
            <h5>Name: ${ctx.displayName}</h5>
            <h5>Display name: ${ctx.fromDisplayName}</h5>
            <h5>Language: ${ctx.email_language}</h5>
            <h5>Date tool: ${ctx.dateTool}</h5>

            <hr />

            <h5>Customer: ${ctx.customerModel}</h5>
            <h5>Customer id: ${ctx.customerModel.getCustomerID()}</h5>
            <h5>Customer name: ${ctx.customerModel.getName()}</h5>
            <h5>Customer tokens:</h5>
            <div>
                <ul>
                    #foreach( $token in ${ctx.customerModel.getExternalToken()} )
                        <li>
                            <span>$token.getValue()</span>
                        </li>
                    #end
                </ul>
            </div>
        </div>
        <hr />
        <div>
            <table width="100%" height="100%" cellpadding="0" cellspacing="0" border="0" bgcolor="#F2F5F6">
                <tbody>
                <tr>
                    <td width="100%" valign="top" align="center">
                        <center>
                            <table border="0" cellpadding="0" cellspacing="0" height="100%" width="100%">
                                <tbody>
                                <tr>
                                    <td align="center" height="100%" valign="top" width="100%">
                                        <table align="center" border="0" cellpadding="0" cellspacing="0" width="100%" style="max-width:640px" bgcolor="#F2F5F6">
                                            <tbody>
                                            <tr>
                                                <td height="5" style="font-size: 10px; line-height: 17px;">xxx</td>
                                            </tr>
                                            <tr>
                                                <td height="5" style="font-size: 10px; line-height: 17px;">yyy</td>
                                            </tr>
                                            <tr>
                                                <td bgcolor="#fff" width="640" height="60" valign="top">
                                                    <div>
                                                        <table width="100%" height="100%" border="0" cellpadding="0" cellspacing="0">
                                                            <tbody>
                                                            <!-- header -->
                                                            <div>Header</div>

                                                            <!-- top content slot - intro components-->
                                                            <div>Content Slot</div>

                                                            </tbody>
                                                        </table>
                                                    </div>
                                                </td>
                                            </tr>
                                            </tbody>
                                        </table>
                                    </td>
                                </tr>
                                <!-- content -->
                                <tr>
                                    <td align="center" height="100%" valign="top" width="100%">
                                        <table align="center" border="0" cellpadding="0" cellspacing="0" width="100%" style="max-width:640px; background-color:#fff">
                                            <tbody>
                                            <tr>
                                                <td height="40" style="font-size: 40px; line-height: 40px;">&nbsp;</td>
                                            </tr>
                                            <tr>
                                                <td align="left" valign="top" style="padding-left:20px;">
